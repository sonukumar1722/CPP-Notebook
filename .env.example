# ─── Backend ─────────────────────────────────────────────────────────────────
CPPNOTE_JWT_SECRET=change-me-use-a-strong-random-secret
CPPNOTE_KERNEL_NAME=xcpp17
CPPNOTE_KERNEL_IDLE_TIMEOUT_SECONDS=900
CPPNOTE_WORKSPACE_ROOT=workspaces
CPPNOTE_UPLOAD_ROOT=uploads

# Comma-separated list of allowed frontend origins (include both dev + prod)
# Example: http://localhost:5173,https://cppnote.vercel.app
CPPNOTE_FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL — update for production
CPPNOTE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cppnote

# Single-user credentials
CPPNOTE_USER_EMAIL=admin@cppnote.local
CPPNOTE_USER_PASSWORD=cppnote123
CPPNOTE_DISPLAY_NAME=Developer

# ─── Frontend (Vercel) ────────────────────────────────────────────────────────
# Set this in Vercel Dashboard → Project → Settings → Environment Variables
# VITE_API_URL=https://your-backend-url.com
